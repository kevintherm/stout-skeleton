{
    "name": "stout/scratch",
    "description": "Stout Framework Scratch App",
    "type": "project",
    "require": {
        "php": "^8.3",
        "stout/stout": "*@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require-dev": {
        "pestphp/pest": "^4.7",
        "phpstan/phpstan": "^2.2"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    }
}